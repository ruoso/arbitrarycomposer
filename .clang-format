# The configuration files are the style guide (design doc 16).
# clang-format major version is pinned by CI (19); reformat-only commits go
# in .git-blame-ignore-revs.
BasedOnStyle: LLVM
Standard: c++20
ColumnLimit: 100
IndentWidth: 2
PointerAlignment: Left
DerivePointerAlignment: false
InsertNewlineAtEOF: true
IncludeBlocks: Regroup
IncludeCategories:
  # Own header (main include) is priority 0 by clang-format convention.
  - Regex: '^<arbc/'
    Priority: 2
  - Regex: '^<catch2/'
    Priority: 3
  - Regex: '^<[a-z_]+>$'
    Priority: 5
  - Regex: '.*'
    Priority: 4
