{
  "version": 5,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Debug + tests",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release + tests",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "asan",
      "displayName": "Debug + ASan/UBSan",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/asan",
      "cacheVariables": {
        "ARBC_SANITIZERS": "address,undefined"
      }
    },
    {
      "name": "tsan",
      "displayName": "Debug + ThreadSanitizer",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/tsan",
      "cacheVariables": {
        "ARBC_SANITIZERS": "thread"
      }
    },
    {
      "name": "rtsan",
      "displayName": "Debug + RealtimeSanitizer (Clang only)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/rtsan",
      "cacheVariables": {
        "ARBC_SANITIZERS": "realtime"
      }
    },
    {
      "name": "coverage",
      "displayName": "Debug + coverage instrumentation",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/coverage",
      "cacheVariables": {
        "ARBC_COVERAGE": "ON"
      }
    },
    {
      "name": "fuzz",
      "displayName": "Debug + libFuzzer loader harness (Clang only)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/fuzz",
      "cacheVariables": {
        "ARBC_FUZZER": "ON",
        "ARBC_SANITIZERS": "address,undefined,fuzzer-no-link"
      }
    },
    {
      "name": "install-fetched",
      "displayName": "Debug + tests, every dependency FETCHED (never found)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/install-fetched",
      "cacheVariables": {
        "FETCHCONTENT_TRY_FIND_PACKAGE_MODE": "NEVER"
      }
    },
    {
      "name": "win-dev",
      "displayName": "Debug + tests (Ninja, for MSVC dev prompts)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/win-dev",
      "generator": "Ninja"
    },
    {
      "name": "bench",
      "displayName": "Release + Google Benchmark (opt-in, off the merge path)",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/bench",
      "cacheVariables": {
        "ARBC_BENCHMARKS": "ON"
      }
    },
    {
      "name": "shared",
      "displayName": "Debug + tests, BUILD_SHARED_LIBS=ON (libarbc.so)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/shared",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "win-shared",
      "displayName": "Debug + tests, BUILD_SHARED_LIBS=ON (Ninja/MSVC, arbc.dll)",
      "inherits": "win-dev",
      "binaryDir": "${sourceDir}/build/win-shared",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "dev", "configurePreset": "dev" },
    { "name": "release", "configurePreset": "release" },
    { "name": "asan", "configurePreset": "asan" },
    { "name": "tsan", "configurePreset": "tsan" },
    { "name": "rtsan", "configurePreset": "rtsan" },
    { "name": "coverage", "configurePreset": "coverage" },
    { "name": "fuzz", "configurePreset": "fuzz" },
    { "name": "install-fetched", "configurePreset": "install-fetched" },
    { "name": "win-dev", "configurePreset": "win-dev" },
    { "name": "bench", "configurePreset": "bench" },
    { "name": "shared", "configurePreset": "shared" },
    { "name": "win-shared", "configurePreset": "win-shared" }
  ],
  "testPresets": [
    { "name": "dev", "configurePreset": "dev", "output": { "outputOnFailure": true } },
    { "name": "release", "configurePreset": "release", "output": { "outputOnFailure": true } },
    { "name": "asan", "configurePreset": "asan", "output": { "outputOnFailure": true } },
    { "name": "tsan", "configurePreset": "tsan", "output": { "outputOnFailure": true } },
    { "name": "rtsan", "configurePreset": "rtsan", "output": { "outputOnFailure": true } },
    { "name": "coverage", "configurePreset": "coverage", "output": { "outputOnFailure": true } },
    { "name": "fuzz", "configurePreset": "fuzz", "output": { "outputOnFailure": true } },
    { "name": "install-fetched", "configurePreset": "install-fetched", "output": { "outputOnFailure": true } },
    { "name": "win-dev", "configurePreset": "win-dev", "output": { "outputOnFailure": true } },
    { "name": "bench", "configurePreset": "bench", "output": { "outputOnFailure": true } },
    { "name": "shared", "configurePreset": "shared", "output": { "outputOnFailure": true } },
    { "name": "win-shared", "configurePreset": "win-shared", "output": { "outputOnFailure": true } }
  ]
}
