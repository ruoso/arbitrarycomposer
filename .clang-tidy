# Curated profile (design doc 16). Every disabled check carries a reason.
# Runs in the nightly workflow until the baseline is clean, then per-push.
#
# Disabled:
#   bugprone-easily-swappable-parameters — geometry/color APIs are
#     inherently (x, y) / (r, g, b, a) shaped; the check is all noise here.
#   modernize-use-trailing-return-type — style choice: leading return types.
Checks: >
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  performance-*,
  concurrency-*,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-use-equals-default,
  readability-identifier-naming
WarningsAsErrors: '*'
CheckOptions:
  readability-identifier-naming.NamespaceCase: lower_case
  readability-identifier-naming.ClassCase: CamelCase
  readability-identifier-naming.StructCase: CamelCase
  readability-identifier-naming.EnumCase: CamelCase
  readability-identifier-naming.EnumConstantCase: CamelCase
  readability-identifier-naming.FunctionCase: lower_case
  readability-identifier-naming.VariableCase: lower_case
  readability-identifier-naming.ParameterCase: lower_case
  readability-identifier-naming.PrivateMemberPrefix: d_
  readability-identifier-naming.PrivateMemberCase: lower_case
  readability-identifier-naming.StaticVariablePrefix: s_
  readability-identifier-naming.StaticVariableCase: lower_case
  readability-identifier-naming.ConstexprVariableCase: lower_case
